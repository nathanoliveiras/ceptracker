version: '3.8'

services:

  postgres:
    image: postgres:15
    container_name: cep-postgres
    environment:
      POSTGRES_DB: cepdb
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"

  app:
    build: .
    container_name: cep-app
    depends_on:
      - postgres
    ports:
      - "8080:8080"